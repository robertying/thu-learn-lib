{
  "name": "thu-learn-lib",
  "version": "4.0.0",
  "description": "a JavaScript library to provide a program-friendly interface to Web Learning (2018) of Tsinghua University",
  "type": "module",
  "files": [
    "lib"
  ],
  "main": "./lib/module/index.js",
  "exports": {
    ".": {
      "types": "./lib/typescript/index.d.ts",
      "default": "./lib/module/index.js"
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "scripts": {
    "build": "bob build",
    "dev": "vite",
    "dev:build": "vite build",
    "format": "prettier --write \"{src,test,demo}/**/*.{ts,html,json}\" \"*.{ts,md,json}\"",
    "lint": "eslint",
    "test": "OPENSSL_CONF=openssl.cnf vitest run"
  },
  "keywords": [
    "tsinghua",
    "learn2018"
  ],
  "author": "Harry Chen <harry-chen@outlook.com> (https://harrychen.xyz)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Harry-Chen/thu-learn-lib.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/sm-crypto": "^0.3.4",
    "@types/tough-cookie": "^4.0.5",
    "@types/webextension-polyfill": "^0.12.5",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "domhandler": "^6.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "fake-parse5": "^0.0.2",
    "prettier": "^3.8.4",
    "react-native-builder-bob": "^0.42.1",
    "terser": "^5.48.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-web-extension": "^4.5.1",
    "vitest": "^4.1.8",
    "webextension-polyfill": "^0.12.0"
  },
  "dependencies": {
    "cheerio": "1.0.0-rc.12",
    "entities": "^8.0.0",
    "fetch-cookie": "3.0.1",
    "js-base64": "^3.7.8",
    "node-fetch-native": "^1.6.7",
    "sm-crypto": "^0.4.0",
    "tough-cookie": "4.1.4"
  },
  "packageManager": "yarn@4.16.0+sha512.5374c94eb4ef6aa8188fb112f20c1aa6569f248d676c5e576e1fd2a1a4d8d87a96df65d9dfe1c2a0252cbe38bda46cf18d955005b81b43cc7607a5c9d56fd2b6"
}
